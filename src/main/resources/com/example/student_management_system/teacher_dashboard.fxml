<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.student_management_system.TeacherDashboardController"
            stylesheets="@teacher_dashboard.css"
            prefWidth="1200" prefHeight="800">

    <!-- TOP HEADER -->
    <top>
        <HBox spacing="20" styleClass="top-header" alignment="CENTER_LEFT">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <VBox spacing="4">
                <Label text="BUET" styleClass="header-title"/>
                <Label text="Bangladesh University of Engineering and Technology" styleClass="header-subtitle"/>
                <Label text="Teacher Management Portal" styleClass="header-small"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="logout-button"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR wrapped in ScrollPane for scrollability -->
    <left>
        <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="6" styleClass="sidebar" prefWidth="235">
                    <padding><Insets top="20" right="12" bottom="20" left="12"/></padding>

                    <VBox spacing="5" styleClass="teacher-mini-card">
                        <Label fx:id="sidebarNameLabel" text="Teacher Name" styleClass="teacher-mini-name"/>
                        <Label fx:id="sidebarIdLabel" text="teacher@buet.ac.bd" styleClass="teacher-mini-id"/>
                        <Label fx:id="sidebarDeptLabel" text="CSE Department" styleClass="teacher-mini-dept"/>
                    </VBox>

                    <Label text="MAIN" styleClass="sidebar-section-label"/>
                    <Button text="🏠  Dashboard" onAction="#showHome" styleClass="sidebar-button"/>
                    <Button text="👤  My Profile" onAction="#showProfile" styleClass="sidebar-button"/>

                    <Separator style="-fx-background-color: #333333;"/>
                    <Label text="ACADEMIC" styleClass="sidebar-section-label"/>
                    <Button text="📚  My Courses" onAction="#showCourses" styleClass="sidebar-button"/>
                    <Button text="📋  Attendance" onAction="#showAttendance" styleClass="sidebar-button"/>
                    <Button text="📝  Marks &amp; Grades" onAction="#showMarks" styleClass="sidebar-button"/>
                    <Button text="📎  Assignments" onAction="#showAssignments" styleClass="sidebar-button"/>

                    <Separator style="-fx-background-color: #333333;"/>
                    <Label text="COMMUNICATION" styleClass="sidebar-section-label"/>
                    <Button text="📢  Announcements" onAction="#showAnnouncements" styleClass="sidebar-button"/>
                    <Button text="👥  Student List" onAction="#showStudents" styleClass="sidebar-button"/>
                </VBox>
            </content>
        </ScrollPane>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane fx:id="contentPane" styleClass="main-content">

            <!-- HOME SECTION -->
            <ScrollPane fx:id="homeSection" fitToWidth="true" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="Teacher Dashboard" styleClass="section-title"/>
                            <Label text="Welcome to your BUET teacher portal" styleClass="section-subtitle"/>
                        </VBox>

                        <!-- Stat Cards -->
                        <HBox spacing="15">
                            <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                <Label fx:id="statCourses" text="4" styleClass="stat-value"/>
                                <Label text="Courses Assigned" styleClass="stat-label"/>
                                <Label text="This Semester" styleClass="field-label"/>
                            </VBox>
                            <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                <Label fx:id="statStudents" text="128" styleClass="stat-value"/>
                                <Label text="Total Students" styleClass="stat-label"/>
                                <Label text="Across all courses" styleClass="field-label"/>
                            </VBox>
                            <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                <Label fx:id="statAttendance" text="87%" styleClass="stat-value"/>
                                <Label text="Avg Attendance" styleClass="stat-label"/>
                                <Label text="All classes" styleClass="field-label"/>
                            </VBox>
                            <VBox spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                <Label fx:id="statAssignments" text="6" styleClass="stat-value"/>
                                <Label text="Active Assignments" styleClass="stat-label"/>
                                <Label text="Pending review" styleClass="field-label"/>
                            </VBox>
                        </HBox>

                        <!-- Profile Overview -->
                        <VBox spacing="15" styleClass="card">
                            <Label text="Profile Overview" styleClass="card-title"/>
                            <HBox spacing="40">
                                <VBox spacing="8">
                                    <Label text="Full Name:" styleClass="field-label"/>
                                    <Label fx:id="homeNameLabel" text="Prof. Rahman" styleClass="field-value"/>
                                    <Label text="Employee ID:" styleClass="field-label"/>
                                    <Label fx:id="homeIdLabel" text="TCH-001" styleClass="field-value"/>
                                    <Label text="Department:" styleClass="field-label"/>
                                    <Label fx:id="homeDeptLabel" text="CSE" styleClass="field-value"/>
                                </VBox>
                                <VBox spacing="8">
                                    <Label text="Designation:" styleClass="field-label"/>
                                    <Label fx:id="homeDesigLabel" text="Associate Professor" styleClass="field-value"/>
                                    <Label text="Email:" styleClass="field-label"/>
                                    <Label fx:id="homeEmailLabel" text="rahman@cse.buet.ac.bd" styleClass="field-value"/>
                                    <Label text="Current Semester:" styleClass="field-label"/>
                                    <Label text="Level 2, Term 1  |  Session 2024–25" styleClass="field-value"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Today's Classes -->
                        <VBox spacing="12" styleClass="card">
                            <Label text="Today's Classes" styleClass="card-title"/>
                            <VBox fx:id="todaysClassesBox" spacing="8"/>
                        </VBox>

                        <!-- Recent Activity -->
                        <VBox spacing="12" styleClass="card">
                            <Label text="Recent Activity" styleClass="card-title"/>
                            <VBox fx:id="recentActivityBox" spacing="8"/>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- PROFILE SECTION -->
            <ScrollPane fx:id="profileSection" fitToWidth="true" visible="false" managed="false" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="My Profile" styleClass="section-title"/>
                            <Label text="Personal and professional information" styleClass="section-subtitle"/>
                        </VBox>
                        <VBox spacing="15" styleClass="card">
                            <Label text="Personal Information" styleClass="card-title"/>
                            <HBox spacing="50">
                                <VBox spacing="10">
                                    <Label text="Full Name:" styleClass="field-label"/>
                                    <Label fx:id="profNameLabel" text="Prof. Rahman" styleClass="field-value"/>
                                    <Label text="Employee ID:" styleClass="field-label"/>
                                    <Label fx:id="profIdLabel" text="TCH-001" styleClass="field-value"/>
                                    <Label text="Department:" styleClass="field-label"/>
                                    <Label fx:id="profDeptLabel" text="CSE" styleClass="field-value"/>
                                    <Label text="Designation:" styleClass="field-label"/>
                                    <Label fx:id="profDesigLabel" text="Associate Professor" styleClass="field-value"/>
                                </VBox>
                                <VBox spacing="10">
                                    <Label text="Email:" styleClass="field-label"/>
                                    <Label fx:id="profEmailLabel" text="rahman@cse.buet.ac.bd" styleClass="field-value"/>
                                    <Label text="Office:" styleClass="field-label"/>
                                    <Label text="Room 412, ECE Building" styleClass="field-value"/>
                                    <Label text="Phone:" styleClass="field-label"/>
                                    <Label text="+880-1712-345678" styleClass="field-value"/>
                                    <Label text="Specialization:" styleClass="field-label"/>
                                    <Label text="Machine Learning, Algorithms" styleClass="field-value"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox spacing="12" styleClass="card">
                            <Label text="Current Course Load" styleClass="card-title"/>
                            <VBox fx:id="profileCourseListBox" spacing="8"/>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- COURSES SECTION — now scrollable -->
            <ScrollPane fx:id="coursesSection" fitToWidth="true" visible="false" managed="false" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="My Courses" styleClass="section-title"/>
                            <Label text="Courses assigned to you this semester" styleClass="section-subtitle"/>
                        </VBox>
                        <VBox fx:id="coursesContentBox" spacing="15"/>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- ATTENDANCE SECTION — now scrollable -->
            <ScrollPane fx:id="attendanceSection" fitToWidth="true" visible="false" managed="false" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="Attendance Management" styleClass="section-title"/>
                            <Label text="Mark and view student attendance" styleClass="section-subtitle"/>
                        </VBox>
                        <VBox fx:id="attendanceContentBox" spacing="15"/>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- MARKS SECTION — now scrollable -->
            <ScrollPane fx:id="marksSection" fitToWidth="true" visible="false" managed="false" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="Marks &amp; Grading" styleClass="section-title"/>
                            <Label text="Enter and manage student marks" styleClass="section-subtitle"/>
                        </VBox>
                        <VBox fx:id="marksContentBox" spacing="15"/>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- ASSIGNMENTS SECTION — now scrollable -->
            <ScrollPane fx:id="assignmentsSection" fitToWidth="true" visible="false" managed="false" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="Assignments" styleClass="section-title"/>
                            <Label text="Create and manage course assignments" styleClass="section-subtitle"/>
                        </VBox>
                        <VBox fx:id="assignmentsContentBox" spacing="15"/>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- ANNOUNCEMENTS SECTION — now scrollable -->
            <ScrollPane fx:id="announcementsSection" fitToWidth="true" visible="false" managed="false" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="Announcements" styleClass="section-title"/>
                            <Label text="Send notices to your students" styleClass="section-subtitle"/>
                        </VBox>
                        <VBox fx:id="announcementsContentBox" spacing="15"/>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- STUDENTS SECTION — now scrollable -->
            <ScrollPane fx:id="studentsSection" fitToWidth="true" visible="false" managed="false" styleClass="content-scroll">
                <content>
                    <VBox spacing="18" styleClass="section-container">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <VBox spacing="4" styleClass="section-header-box">
                            <Label text="Student List" styleClass="section-title"/>
                            <Label text="View students enrolled in your courses" styleClass="section-subtitle"/>
                        </VBox>
                        <VBox fx:id="studentsContentBox" spacing="15"/>
                    </VBox>
                </content>
            </ScrollPane>

        </StackPane>
    </center>
</BorderPane>
